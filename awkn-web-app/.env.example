# AWKN Next.js app — environment variables
#
# Copy this file to .env.local and fill in values. Values committed to git
# are public-by-design — anon key is already exposed in the legacy BOS at
# shared/supabase.js. Server-only secrets (service role key, DATABASE_URL)
# must NEVER be committed.

# --- Required at all times ---
# Live AWKN prod project. Same values used by legacy BOS today.
NEXT_PUBLIC_SUPABASE_URL="https://lnqxarwqckpmirpmixcw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxucXhhcndxY2twbWlycG1peGN3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMjAyMDIsImV4cCI6MjA4NzY5NjIwMn0.bw8b5XUcEFExlfTrR78Bu4Vdl7Oe_RtjlgvWA7SlQfo"

# --- Dev-only convenience ---
# When "true", middleware skips auth checks on /portal/* and /bos/* so you
# can click around without logging in. Never set in production.
NEXT_PUBLIC_DISABLE_AUTH="true"

# --- Required for env validation; placeholder OK in Phase 2.1 ---
# Drizzle is created lazily — placeholder URL never connects until Phase 2.3
# wires up real introspection. Replace with the real Supabase connection
# string from Dashboard → Project Settings → Database when ready.
DATABASE_URL="postgresql://placeholder:placeholder@127.0.0.1:54322/postgres"

# --- Required from Phase 2.4 onward (server-side admin calls) ---
# Get from Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY="..."
