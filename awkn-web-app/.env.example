# AWKN Next.js app — environment variables
#
# Copy this file to .env.local and fill in values. Anon key is public-by-
# design (already exposed in legacy BOS at shared/supabase.js). The DB
# password and service role key MUST NEVER be committed.

# --- Required at all times (Supabase client / Auth) ---
NEXT_PUBLIC_SUPABASE_URL="https://lnqxarwqckpmirpmixcw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxucXhhcndxY2twbWlycG1peGN3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMjAyMDIsImV4cCI6MjA4NzY5NjIwMn0.bw8b5XUcEFExlfTrR78Bu4Vdl7Oe_RtjlgvWA7SlQfo"

# --- Dev-only convenience ---
# When "true", proxy.ts skips auth checks on /portal/* and /bos/* so you can
# click around without logging in. Never set in production.
NEXT_PUBLIC_DISABLE_AUTH="true"

# --- Database connection (Phase 2.3+ Drizzle introspection + queries) ---
# EASIEST PATH: just paste the password here. The URL gets composed
# automatically (session pooler, sslmode=require, special chars URL-encoded).
# Get / reset at:
#   https://supabase.com/dashboard/project/lnqxarwqckpmirpmixcw/settings/database
SUPABASE_DB_PASSWORD=""

# OR (advanced) set DATABASE_URL directly. Wins over SUPABASE_DB_PASSWORD
# when both are present. Useful for pointing at a different DB or pooler.
# DATABASE_URL="postgresql://postgres.lnqxarwqckpmirpmixcw:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Required from Phase 2.4 onward (server-side admin calls) ---
# Get from Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=""
