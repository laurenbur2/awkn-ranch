# AWKN Next.js app — environment variables
#
# Copy this file to .env.local and fill in values. Anon key is public-by-
# design (already exposed in legacy BOS at shared/supabase.js). Anything
# without a NEXT_PUBLIC_ prefix is server-only and MUST NEVER be committed.
#
# Forward inventory of every env var the new app will eventually need as
# we port edge functions and server-side flows out of legacy. Categorized
# by current-vs-future scope so the dev loop can stay minimal.
#
# Vault locations (where the real values live):
#   - Supabase Dashboard → Project Settings → API
#       https://supabase.com/dashboard/project/lnqxarwqckpmirpmixcw/settings/api
#   - Supabase Dashboard → Edge Functions → Secrets
#       https://supabase.com/dashboard/project/lnqxarwqckpmirpmixcw/functions/secrets
#       (also enumerable by digest via `supabase secrets list`)
#   - Service-specific vendor consoles (Stripe, Resend, SignWell, R2,
#     Google Cloud, AI Studio) — see per-section comments.
#
# Three categories of provider credentials in this codebase:
#   1. Env-var-managed (the list below) — set in Supabase Functions for
#      the legacy stack, mirrored here for the new server-side flows.
#   2. DB-row-managed (Telnyx, WhatsApp/Meta, Square, Tellescope) — live
#      in *_config tables (telnyx_config, whatsapp_config, square_config).
#      Already in the prod DB. Listed at the bottom for awareness.
#   3. Hardcoded in legacy JS (Supabase URL + anon key) — being phased
#      out via this file.

# =============================================================================
# CURRENT — required to run the dev loop
# =============================================================================

# --- Supabase client / Auth (always required) ---
NEXT_PUBLIC_SUPABASE_URL="https://lnqxarwqckpmirpmixcw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxucXhhcndxY2twbWlycG1peGN3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIxMjAyMDIsImV4cCI6MjA4NzY5NjIwMn0.bw8b5XUcEFExlfTrR78Bu4Vdl7Oe_RtjlgvWA7SlQfo"

# --- Dev-only convenience ---
# When "true", proxy.ts skips auth checks on /portal/* and /bos/* AND
# serve-legacy-html.ts injects window.__AWKN_DEV_BYPASS_AUTH=true so legacy
# admin chrome renders against accounts that lack prod permissions. Renders
# chrome only — actual table queries still hit Supabase under the user's
# real RLS role. Never set in production.
NEXT_PUBLIC_DISABLE_AUTH="true"

# --- Database connection (Drizzle introspection + queries) ---
# EASIEST PATH: paste the password here; the URL gets composed automatically
# (session pooler, sslmode=require, special chars URL-encoded). Get/reset at
# the Supabase Dashboard → Settings → Database.
SUPABASE_DB_PASSWORD=""

# OR (advanced) set DATABASE_URL directly. Wins over SUPABASE_DB_PASSWORD
# when both are present. Useful for pointing at a different DB/pooler.
# DATABASE_URL="postgresql://postgres.lnqxarwqckpmirpmixcw:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require"

# --- Server-side admin calls (Phase 2.4+) ---
# Used by `src/server/auth/admin-client.ts` for admin-role queries that
# bypass RLS (e.g. team management, user provisioning).
# Vault: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=""

# =============================================================================
# FUTURE — needed as we port edge functions / server flows out of legacy
# =============================================================================
# All currently set as Supabase Functions secrets in prod (verifiable via
# `supabase secrets list`). Mirror here when porting the corresponding flow
# from supabase/functions/ into a Next.js Route Handler / Server Action.

# --- Stripe (payments — invoices, deposits, payment links) ---
# Used by: create-payment-link, stripe-webhook, send-email (invoice flow).
# Vault: Stripe Dashboard → Developers → API keys
#   - Live: pk_live_... / sk_live_... / whsec_... (rotated by Stripe)
# STRIPE_PUBLISHABLE_KEY=""    # NEXT_PUBLIC_ candidate when client-side checkout lands
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# --- Resend (transactional email) ---
# Used by: send-email, send-email-with-template, signup-confirm-handler.
# Vault: Resend Dashboard → API Keys
#   - WEBHOOK_SECRET signs incoming Resend events (delivery, bounce, etc.)
# RESEND_API_KEY=""
# RESEND_WEBHOOK_SECRET=""

# --- SignWell (e-sign / agreements) ---
# Used by: signwell-webhook (Within agreements + Ranch retreat housing).
# Empirically dormant in prod — tables missing per Pass 5.1 audit.
# Vault: SignWell Dashboard → Developers → API
# SIGNWELL_API_KEY=""

# --- Google Calendar (booking sync) ---
# Used by: google-calendar-* edge functions (within-schedule reservations).
# Vault: Google Cloud Console → APIs & Services → Credentials
#   - REDIRECT_URI must match what's registered with the OAuth client
# GOOGLE_CALENDAR_CLIENT_ID=""
# GOOGLE_CALENDAR_CLIENT_SECRET=""
# GOOGLE_CALENDAR_REDIRECT_URI=""

# --- Gemini (AI — chat widget, content) ---
# Used by: chat-widget answer generation, ai-suggest endpoints.
# Vault: Google AI Studio → API keys
# GEMINI_API_KEY=""

# --- Cron / scheduled jobs ---
# Shared secret that scheduled invocations include in their Authorization
# header so the function can reject unauthorized calls. Used by any
# pg_cron-driven function.
# CRON_SECRET=""

# --- Public site URL (used in email templates + redirects) ---
# Set per-environment: localhost:3000 in dev, the real hostname in prod.
# PUBLIC_SITE_URL="http://localhost:3000"

# =============================================================================
# DB-ROW MANAGED — credentials live in *_config tables, NOT here
# =============================================================================
# Listed for awareness only. Don't add env vars for these — the legacy
# pattern of reading from Postgres is intentional (lets ops rotate without
# redeploying). When porting these flows, read from the same tables.
#
#   Telnyx (SMS)              → telnyx_config
#   WhatsApp / Meta           → whatsapp_config
#   Square (payments)         → square_config (sandbox + production)
#   Tellescope (Within EMR)   → tellescope_config (if/when integrated)
